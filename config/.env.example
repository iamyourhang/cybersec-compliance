# ============================================================
# 网安合规助手 - 环境配置模板
# 复制为 .env 并填入真实值，.env 不提交到 git
# ============================================================

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cybersec_compliance
DB_USER=compliance_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- AI Provider：火山引擎（主力）----
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL_PRIMARY=doubao-seed-2.0-pro
VOLCENGINE_MODEL_FALLBACK=doubao-seed-2.0-lite

# ---- AI Provider：阿里百炼（备用）----
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max

# ---- AI Provider：DeepSeek（备用）----
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- AI Provider：UniAPI（建议主用 OpenAI 兼容网关）----
UNIAPI_API_KEY=your_uniapi_api_key
UNIAPI_BASE_URL=https://uniapi.ruijie.com.cn/
# 可先留空；系统会临时继承当前主模型名，后续再改成你最终选定的模型
UNIAPI_MODEL=

# ---- LLM Router（数据库为空时的兜底通道池）----
LLM_ROUTER_SECRET=replace_with_fernet_key
LLM_ROUTER_FALLBACK_JSON=[{"name":"fallback-openai","provider_type":"openai_compatible","base_url":"https://api.openai.com/v1","api_key":"replace_me","model":"gpt-4.1-mini","priority":1,"enabled":true,"supports_web_search":false}]

# ---- Embedding（OpenAI 兼容接口）----
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---- 飞书通知 ----
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token
FEISHU_WEBHOOK_SECRET=your_webhook_secret
# 飞书机器人（后期查询功能）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书事件回调校验 token（如未启用事件回调可留空）
FEISHU_VERIFICATION_TOKEN=

# ---- 腾讯云 COS（Excel 报告存储）----
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou
COS_REPORT_PREFIX=reports/

# ---- 管理后台 ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
# 配置 ADMIN_SUPER_USERNAME/PASSWORD 后，ADMIN_USERNAME 会自动降级为 viewer。
ADMIN_SUPER_USERNAME=
ADMIN_SUPER_PASSWORD=
# 可选：扩展用户，格式示例：
# ADMIN_USERS_JSON=[{"username":"auditor","password":"change_me","role":"viewer"}]
ADMIN_USERS_JSON=
ADMIN_IP_WHITELIST=127.0.0.1,192.168.1.0/24
ADMIN_JWT_SECRET=your_jwt_secret_here
ADMIN_PORT=8080

# ---- 调度配置 ----
# 全量更新：每周一凌晨1点（cron格式）
SCHEDULE_FULL_UPDATE=0 1 * * 1
# 增量检查：每天凌晨2点
SCHEDULE_INCREMENTAL=0 2 * * *
# 周报发送：每周一早9点
SCHEDULE_WEEKLY_REPORT=0 9 * * 1

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# ---- 运行环境 ----
ENV=production
# development / production
